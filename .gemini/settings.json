{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "context": {
    "fileName": [
      "AGENTS.md",
      "ESCPOS.md",
      "REVIEW.md"
    ],
    "fileFiltering": {
      "respectGitIgnore": true
    }
  },
  "security": {
    "disableYoloMode": true
  },
  "general": {
    "defaultApprovalMode": "plan",
    "plan": {
      "modelRouting": true
    }
  },
  "experimental": {
    "enableAgents": true,
    "plan": true
  },
  "ide": {
    "enabled": true
  }
}